#!/usr/bin/env python3
import argparse
import base64
import configparser
import json
import os
import re
import subprocess
import sys
import urllib.parse
import urllib.request
from datetime import date
from os.path import expanduser
from pathlib import Path
from time import sleep
from urllib.error import HTTPError


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Fetch WakaTime branch time for local branches matching a Jira ticket key."
    )
    parser.add_argument("ticket", help="Jira ticket key, for example SOT-829")
    parser.add_argument("--start", default=str(date.today()), help="Start date in YYYY-MM-DD")
    parser.add_argument("--end", help="End date in YYYY-MM-DD; defaults to --start")
    parser.add_argument(
        "--branch",
        action="append",
        default=[],
        help="Explicit branch name to use. Repeatable.",
    )
    parser.add_argument(
        "--project",
        action="append",
        default=[],
        help="Explicit WakaTime project name to use. Repeatable.",
    )
    parser.add_argument(
        "--search-root",
        default=os.environ.get("CODEX_SKILLS_WORKSPACES_ROOT", str(Path.home() / "Workspaces")),
        help="Root folder for scanning local git repos when no --branch is supplied.",
    )
    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    return parser.parse_args()


def read_api_key() -> str:
    cfg = configparser.ConfigParser()
    cfg.read(os.environ.get("WAKATIME_CONFIG", expanduser("~/.wakatime.cfg")))
    key = cfg.get("settings", "api_key", fallback="").strip()
    if not key:
        raise SystemExit("WakaTime api_key is not configured in ~/.wakatime.cfg")
    return key


def find_git_dirs(search_root: Path) -> list[Path]:
    git_dirs: list[Path] = []
    max_depth = len(search_root.parts) + 5
    for root, dirs, files in os.walk(search_root):
        root_path = Path(root)
        if len(root_path.parts) > max_depth:
            dirs[:] = []
            continue
        if ".git" in dirs or ".git" in files:
            git_dirs.append(root_path)
            dirs[:] = []
    return git_dirs


def branch_list(repo: Path) -> list[str]:
    try:
        result = subprocess.run(
            ["git", "-C", str(repo), "for-each-ref", "refs/heads", "--format=%(refname:short)"],
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError:
        return []
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def find_matches(ticket: str, search_root: Path) -> list[dict]:
    pattern = re.compile(re.escape(ticket.lower()))
    matches: list[dict] = []
    for repo in find_git_dirs(search_root):
        for branch in branch_list(repo):
            if pattern.search(branch.lower()):
                matches.append(
                    {
                        "repo": str(repo),
                        "project": repo.name,
                        "branch": branch,
                    }
                )
    return matches


def fetch_project_branch_summary(api_key: str, start: str, end: str, project: str, branch: str) -> dict:
    params = {
        "start": start,
        "end": end,
        "project": project,
        "branches": branch,
    }
    url = "https://wakatime.com/api/v1/users/current/summaries?" + urllib.parse.urlencode(params)
    auth = base64.b64encode(f"{api_key}:".encode("utf-8")).decode("ascii")
    request = urllib.request.Request(url, headers={"Authorization": f"Basic {auth}"})
    delay = 1
    for attempt in range(4):
        try:
            with urllib.request.urlopen(request, timeout=30) as response:
                return json.load(response)
        except HTTPError as exc:
            if exc.code != 429 or attempt == 3:
                raise
            sleep(delay)
            delay *= 2
    raise SystemExit("WakaTime request failed after retries")


def select_branch_entry(payload: dict, branch: str) -> dict | None:
    days = payload.get("data", [])
    if not days:
        return None
    branches = days[0].get("branches", [])
    branch_lower = branch.lower()
    for item in branches:
        if item.get("name", "").lower() == branch_lower:
            return item
    return None


def main() -> None:
    args = parse_args()
    end = args.end or args.start
    if args.branch and args.project and len(args.branch) != len(args.project):
        raise SystemExit("--branch and --project must have the same number of values")

    matches = []
    if args.branch and args.project:
        matches = [
            {"repo": None, "project": project, "branch": branch}
            for project, branch in zip(args.project, args.branch)
        ]
    else:
        matches = find_matches(args.ticket, Path(args.search_root))

    if not matches:
        raise SystemExit(
            f"No local git branches matched ticket {args.ticket.upper()} under {args.search_root}"
        )

    api_key = read_api_key()
    results = []
    for match in matches:
        payload = fetch_project_branch_summary(
            api_key, args.start, end, match["project"], match["branch"]
        )
        branch_entry = select_branch_entry(payload, match["branch"])
        if branch_entry is None:
            continue
        results.append(
            {
                "ticket": args.ticket.upper(),
                "project": match["project"],
                "branch": match["branch"],
                "repo": match["repo"],
                "start": args.start,
                "end": end,
                "time_text": branch_entry.get("text", "0 secs"),
                "total_seconds": branch_entry.get("total_seconds", 0),
                "percent_of_project_day": branch_entry.get("percent"),
            }
        )

    if not results:
        raise SystemExit(
            f"Found local branches for {args.ticket.upper()}, but WakaTime returned no matching branch stats."
        )

    if args.json:
        print(json.dumps(results, indent=2))
        return

    for result in results:
        print(f"ticket: {result['ticket']}")
        print(f"range: {result['start']} -> {result['end']}")
        print(f"project: {result['project']}")
        print(f"branch: {result['branch']}")
        print(f"time: {result['time_text']}")
        if result["repo"]:
            print(f"repo: {result['repo']}")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
