#!/usr/bin/env python3
import argparse
import base64
import configparser
import json
import os
import sys
import urllib.parse
import urllib.request
from datetime import date
from pathlib import Path
from time import sleep
from urllib.error import HTTPError


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="List branch time from WakaTime, optionally filtered by project name."
    )
    parser.add_argument("--start", default=str(date.today()), help="Start date in YYYY-MM-DD")
    parser.add_argument("--end", help="End date in YYYY-MM-DD; defaults to --start")
    parser.add_argument(
        "--project-match",
        action="append",
        default=[],
        help="Substring filter for WakaTime project names. Repeatable.",
    )
    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    return parser.parse_args()


def read_api_key() -> str:
    cfg = configparser.ConfigParser()
    cfg.read("/Users/lukestembp/.wakatime.cfg")
    key = cfg.get("settings", "api_key", fallback="").strip()
    if not key:
        raise SystemExit("WakaTime api_key is not configured in ~/.wakatime.cfg")
    return key


def local_project_names(search_root: Path) -> set[str]:
    names: set[str] = set()
    max_depth = len(search_root.parts) + 5
    for root, dirs, files in os.walk(search_root):
        root_path = Path(root)
        if len(root_path.parts) > max_depth:
            dirs[:] = []
            continue
        if ".git" in dirs or ".git" in files:
            names.add(root_path.name)
            dirs[:] = []
    return names


def fetch_json(api_key: str, url: str) -> dict:
    auth = base64.b64encode(f"{api_key}:".encode("utf-8")).decode("ascii")
    request = urllib.request.Request(url, headers={"Authorization": f"Basic {auth}"})
    delay = 1
    for attempt in range(4):
        try:
            with urllib.request.urlopen(request, timeout=30) as response:
                return json.load(response)
        except HTTPError as exc:
            if exc.code != 429 or attempt == 3:
                raise
            sleep(delay)
            delay *= 2
    raise SystemExit("WakaTime request failed after retries")


def project_names(api_key: str, start: str, end: str) -> list[str]:
    params = urllib.parse.urlencode({"start": start, "end": end})
    url = f"https://wakatime.com/api/v1/users/current/projects?{params}"
    payload = fetch_json(api_key, url)
    names = [item.get("name") for item in payload.get("data", []) if item.get("name")]
    return names


def branches_for_project(api_key: str, start: str, end: str, project: str) -> list[dict]:
    params = urllib.parse.urlencode({"start": start, "end": end, "project": project})
    url = f"https://wakatime.com/api/v1/users/current/summaries?{params}"
    payload = fetch_json(api_key, url)
    days = payload.get("data", [])
    if not days:
        return []
    return days[0].get("branches", [])


def main() -> None:
    args = parse_args()
    end = args.end or args.start
    api_key = read_api_key()
    filters = [value.lower() for value in args.project_match]

    projects = project_names(api_key, args.start, end)
    local_projects = local_project_names(Path("/Users/lukestembp/Workspaces"))
    projects = [project for project in projects if project in local_projects]
    if filters:
        projects = [
            project
            for project in projects
            if any(project_filter in project.lower() for project_filter in filters)
        ]

    rows = []
    for project in projects:
        for branch in branches_for_project(api_key, args.start, end, project):
            rows.append(
                {
                    "project": project,
                    "branch": branch.get("name"),
                    "time_text": branch.get("text", "0 secs"),
                    "total_seconds": branch.get("total_seconds", 0),
                }
            )

    rows = [row for row in rows if row["branch"] and row["total_seconds"]]
    rows.sort(key=lambda row: row["total_seconds"], reverse=True)

    payload = {"start": args.start, "end": end, "rows": rows}
    if args.json:
        print(json.dumps(payload, indent=2))
        return

    print(f"range: {args.start} -> {end}")
    for row in rows:
        print(f"{row['time_text']}\t{row['project']}\t{row['branch']}")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
